{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bitwage Partner API",
  "colors": {
    "primary": "#0066FF",
    "light": "#3388FF",
    "dark": "#0044CC"
  },
  "favicon": "/images/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "guides/authentication"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "guides/terminology",
              "guides/private-label",
              "guides/webhooks",
              "guides/idempotency"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.yaml"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.bitwage.com",
          "icon": "gauge"
        },
        {
          "anchor": "Website",
          "href": "https://www.bitwage.com",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/bitwage-logo.svg",
    "dark": "/images/bitwage-logo-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:developers@bitwage.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.bitwage.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/Bitwage",
      "linkedin": "https://www.linkedin.com/company/bitwage",
      "github": "https://github.com/nicobitwage"
    }
  }
}
